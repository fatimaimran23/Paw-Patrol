# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── SQL Server ────────────────────────────────────────────────
# Windows Auth  → keep DB_TRUSTED_CONNECTION=true, leave USER/PASSWORD blank
# SQL Auth      → set DB_TRUSTED_CONNECTION=false, fill DB_USER and DB_PASSWORD
DB_SERVER=localhost
DB_NAME=PawPatrol
DB_USER=
DB_PASSWORD=
DB_TRUSTED_CONNECTION=true
DB_PORT=1433

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_before_deploying
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
